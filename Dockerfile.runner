# Slim Python image with coverage + pytest preinstalled.
# Used by DockerTestRunner to execute generated tests in a sandbox.
#
# Build:
#   docker build -f Dockerfile.runner -t xsmith-runner:latest .
FROM python:3.11-slim

RUN pip install --no-cache-dir \
    pytest==8.3.4 \
    coverage==7.6.1 \
    pydantic==2.7.4 \
    httpx==0.27.0 \
    requests==2.31.0 \
    click==8.1.7 \
    rich==13.7.0 \
    attrs==23.2.0

WORKDIR /work
